{
  "name": "@pacto-connect/elements",
  "version": "0.0.0",
  "description": "Web-component / iframe embed of Pacto Connect for non-React sites.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run"
  },
  "dependencies": {
    "@pacto-connect/core": "*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.5.2",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
